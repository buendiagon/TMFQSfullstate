@PACKAGE_INIT@

include(CMakeFindDependencyMacro)

list(APPEND CMAKE_MODULE_PATH "${CMAKE_CURRENT_LIST_DIR}")

if(@TMFQS_HAS_BLOSC2@)
	find_dependency(Blosc2)
endif()

if(@TMFQS_HAS_ZFP@)
	find_dependency(ZFP)
endif()

include("${CMAKE_CURRENT_LIST_DIR}/TMFQSTargets.cmake")

check_required_components(TMFQS)
